# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Razorpay — https://dashboard.razorpay.com/app/keys
# TEST keys (rzp_test_...) — no real money; use for development
# LIVE keys (rzp_live_...) — real payments; requires KYC activation on Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_SECRET=your_test_secret_here

# Optional: for live webhook verification (Dashboard → Webhooks)
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

ADMIN_EMAIL=admin@college.edu
ADMIN_PASSWORD=change_me_in_production
PORT=3000
